# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directories
**/.terraform/

# Terraform variable files (tenant-specific, contains identifiers but no secrets)
tenant.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

.terraform.tfstate.lock.info
